{
  "name": "i18n-toolkit-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "yarn build:electron && node ./node_modules/vite/bin/vite.js build",
    "dist": "yarn build && electron-builder",
    "dist:win": "yarn build && electron-builder --win dir",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/typescript/bin/tsc -p tsconfig.electron.json --noEmit",
    "preview": "node scripts/preview.mjs"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@monaco-editor/react": "^4.7.0",
    "harmonyos-sans": "^1.0.0",
    "lucide-react": "^1.24.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "build": {
    "appId": "com.i18n-toolkit.app",
    "productName": "i18n-toolkit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "i18n-toolkit-python",
        "to": "i18n-toolkit-python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signExecutable": false
    }
  }
}
